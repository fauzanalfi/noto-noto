{
  "$schema": "https://tr.designtokens.org/format/",
  "$metadata": {
    "name": "Noto Design System",
    "version": "1.0.0",
    "date": "2026-03-06",
    "description": "W3C DTCG-format design tokens for the Noto note-taking app. Each token includes a $extensions.cssVar field mapping to the CSS custom property in src/index.css."
  },

  "color": {
    "$description": "All color values. Semantic tokens are resolved per theme in src/index.css.",

    "brand": {
      "$description": "Primitive brand colors — do not use directly in components.",
      "purple-400": {
        "$type": "color",
        "$value": "#9485f7",
        "$extensions": { "cssVar": null }
      },
      "purple-500": {
        "$type": "color",
        "$value": "#7c6aef",
        "$extensions": { "cssVar": null }
      },
      "purple-600": {
        "$type": "color",
        "$value": "#6c5ce7",
        "$extensions": { "cssVar": null }
      },
      "blue-400": {
        "$type": "color",
        "$value": "#7aabf7",
        "$extensions": { "cssVar": null }
      },
      "blue-500": {
        "$type": "color",
        "$value": "#5b8def",
        "$extensions": { "cssVar": null }
      },
      "blue-600": {
        "$type": "color",
        "$value": "#4a80e0",
        "$extensions": { "cssVar": null }
      },
      "sepia-500": {
        "$type": "color",
        "$value": "#8b7355",
        "$extensions": { "cssVar": null }
      },
      "forest-500": {
        "$type": "color",
        "$value": "#7a8f5e",
        "$extensions": { "cssVar": null }
      }
    },

    "semantic": {
      "$description": "Theme-resolved semantic tokens. Values shown are for the dark theme (default). See src/index.css for light and eyecare overrides.",

      "dark": {
        "bg-primary":     { "$type": "color", "$value": "#1a1b2e", "$extensions": { "cssVar": "--bg-primary" } },
        "bg-secondary":   { "$type": "color", "$value": "#222340", "$extensions": { "cssVar": "--bg-secondary" } },
        "bg-tertiary":    { "$type": "color", "$value": "#2a2b4a", "$extensions": { "cssVar": "--bg-tertiary" } },
        "bg-hover":       { "$type": "color", "$value": "#32335a", "$extensions": { "cssVar": "--bg-hover" } },
        "bg-active":      { "$type": "color", "$value": "#3a3b6a", "$extensions": { "cssVar": "--bg-active" } },
        "bg-card":        { "$type": "color", "$value": "#252645", "$extensions": { "cssVar": "--bg-card" } },
        "bg-input":       { "$type": "color", "$value": "#1e1f38", "$extensions": { "cssVar": "--bg-input" } },
        "text-primary":   { "$type": "color", "$value": "#e8e8f0", "$extensions": { "cssVar": "--text-primary" } },
        "text-secondary": { "$type": "color", "$value": "#9d9db8", "$extensions": { "cssVar": "--text-secondary" } },
        "text-tertiary":  { "$type": "color", "$value": "#6b6b88", "$extensions": { "cssVar": "--text-tertiary" } },
        "text-accent":    { "$type": "color", "$value": "#a098f0", "$extensions": { "cssVar": "--text-accent" } },
        "text-on-accent": { "$type": "color", "$value": "#ffffff", "$extensions": { "cssVar": "--text-on-accent" } },
        "accent-primary": { "$type": "color", "$value": "#7c6aef", "$extensions": { "cssVar": "--accent-primary" } },
        "accent-primary-hover": { "$type": "color", "$value": "#9485f7", "$extensions": { "cssVar": "--accent-primary-hover" } },
        "accent-secondary": { "$type": "color", "$value": "#5b8def", "$extensions": { "cssVar": "--accent-secondary" } }
      },

      "light": {
        "bg-primary":     { "$type": "color", "$value": "#f5f5f7", "$extensions": { "cssVar": "--bg-primary" } },
        "bg-secondary":   { "$type": "color", "$value": "#ffffff", "$extensions": { "cssVar": "--bg-secondary" } },
        "bg-tertiary":    { "$type": "color", "$value": "#ecedf0", "$extensions": { "cssVar": "--bg-tertiary" } },
        "bg-hover":       { "$type": "color", "$value": "#e8e9ee", "$extensions": { "cssVar": "--bg-hover" } },
        "bg-active":      { "$type": "color", "$value": "#dddee5", "$extensions": { "cssVar": "--bg-active" } },
        "bg-card":        { "$type": "color", "$value": "#ffffff", "$extensions": { "cssVar": "--bg-card" } },
        "bg-input":       { "$type": "color", "$value": "#f0f1f4", "$extensions": { "cssVar": "--bg-input" } },
        "text-primary":   { "$type": "color", "$value": "#1a1a2e", "$extensions": { "cssVar": "--text-primary" } },
        "text-secondary": { "$type": "color", "$value": "#5a5a72", "$extensions": { "cssVar": "--text-secondary" } },
        "text-tertiary":  { "$type": "color", "$value": "#9a9ab0", "$extensions": { "cssVar": "--text-tertiary" } },
        "text-accent":    { "$type": "color", "$value": "#6c5ce7", "$extensions": { "cssVar": "--text-accent" } },
        "text-on-accent": { "$type": "color", "$value": "#ffffff", "$extensions": { "cssVar": "--text-on-accent" } },
        "accent-primary": { "$type": "color", "$value": "#6c5ce7", "$extensions": { "cssVar": "--accent-primary" } },
        "accent-primary-hover": { "$type": "color", "$value": "#7f71ed", "$extensions": { "cssVar": "--accent-primary-hover" } },
        "accent-secondary": { "$type": "color", "$value": "#4a80e0", "$extensions": { "cssVar": "--accent-secondary" } }
      },

      "eyecare": {
        "bg-primary":     { "$type": "color", "$value": "#f5f0e8", "$extensions": { "cssVar": "--bg-primary" } },
        "bg-secondary":   { "$type": "color", "$value": "#ece5d8", "$extensions": { "cssVar": "--bg-secondary" } },
        "bg-tertiary":    { "$type": "color", "$value": "#e2d9ca", "$extensions": { "cssVar": "--bg-tertiary" } },
        "bg-hover":       { "$type": "color", "$value": "#d9cfbe", "$extensions": { "cssVar": "--bg-hover" } },
        "bg-active":      { "$type": "color", "$value": "#d0c4b0", "$extensions": { "cssVar": "--bg-active" } },
        "bg-card":        { "$type": "color", "$value": "#ede6da", "$extensions": { "cssVar": "--bg-card" } },
        "bg-input":       { "$type": "color", "$value": "#ebe4d6", "$extensions": { "cssVar": "--bg-input" } },
        "text-primary":   { "$type": "color", "$value": "#3d3224", "$extensions": { "cssVar": "--text-primary" } },
        "text-secondary": { "$type": "color", "$value": "#6b5e4e", "$extensions": { "cssVar": "--text-secondary" } },
        "text-tertiary":  { "$type": "color", "$value": "#9a8d7c", "$extensions": { "cssVar": "--text-tertiary" } },
        "text-accent":    { "$type": "color", "$value": "#7a6545", "$extensions": { "cssVar": "--text-accent" } },
        "text-on-accent": { "$type": "color", "$value": "#ffffff", "$extensions": { "cssVar": "--text-on-accent" } },
        "accent-primary": { "$type": "color", "$value": "#8b7355", "$extensions": { "cssVar": "--accent-primary" } },
        "accent-primary-hover": { "$type": "color", "$value": "#9e8568", "$extensions": { "cssVar": "--accent-primary-hover" } },
        "accent-secondary": { "$type": "color", "$value": "#7a8f5e", "$extensions": { "cssVar": "--accent-secondary" } }
      }
    },

    "para": {
      "$description": "PARA category colors. Values listed for dark theme; see color.md for all themes.",
      "inbox": {
        "$type": "color",
        "$value": "#6a9eef",
        "$extensions": { "cssVar": "--para-inbox" }
      },
      "projects": {
        "$type": "color",
        "$value": "#ef6a6a",
        "$extensions": { "cssVar": "--para-projects" }
      },
      "areas": {
        "$type": "color",
        "$value": "#efb86a",
        "$extensions": { "cssVar": "--para-areas" }
      },
      "resources": {
        "$type": "color",
        "$value": "#6aef8a",
        "$extensions": { "cssVar": "--para-resources" }
      },
      "archive": {
        "$type": "color",
        "$value": "#8a8aa0",
        "$extensions": { "cssVar": "--para-archive" }
      }
    },

    "status": {
      "$description": "Semantic status colors. Values listed for dark theme.",
      "danger": {
        "$type": "color",
        "$value": "#ef4444",
        "$extensions": { "cssVar": "--color-danger" }
      },
      "danger-hover": {
        "$type": "color",
        "$value": "#f87171",
        "$extensions": { "cssVar": "--color-danger-hover" }
      },
      "success": {
        "$type": "color",
        "$value": "#22c55e",
        "$extensions": { "cssVar": "--color-success" }
      },
      "warning": {
        "$type": "color",
        "$value": "#f59e0b",
        "$extensions": { "cssVar": "--color-warning" }
      },
      "info": {
        "$type": "color",
        "$value": "#5b8def",
        "$description": "Resolves to --accent-secondary via var()",
        "$extensions": { "cssVar": "--color-info" }
      }
    }
  },

  "typography": {
    "$description": "Type scale and font stack tokens.",

    "fontFamily": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif"],
        "$extensions": { "cssVar": "--font-sans" }
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "Fira Code", "Cascadia Code", "monospace"],
        "$extensions": { "cssVar": "--font-mono" }
      }
    },

    "fontSize": {
      "xs":   { "$type": "dimension", "$value": "0.6875rem", "$description": "11px — labels, counts", "$extensions": { "cssVar": "--font-size-xs" } },
      "sm":   { "$type": "dimension", "$value": "0.8125rem", "$description": "13px — body copy, card titles", "$extensions": { "cssVar": "--font-size-sm" } },
      "base": { "$type": "dimension", "$value": "0.9375rem", "$description": "15px — default body", "$extensions": { "cssVar": "--font-size-base" } },
      "md":   { "$type": "dimension", "$value": "1rem",      "$description": "16px — panel headings", "$extensions": { "cssVar": "--font-size-md" } },
      "lg":   { "$type": "dimension", "$value": "1.125rem",  "$description": "18px — sidebar brand, section headings", "$extensions": { "cssVar": "--font-size-lg" } },
      "xl":   { "$type": "dimension", "$value": "1.375rem",  "$description": "22px — note title input", "$extensions": { "cssVar": "--font-size-xl" } },
      "2xl":  { "$type": "dimension", "$value": "1.75rem",   "$description": "28px — markdown H1", "$extensions": { "cssVar": "--font-size-2xl" } },
      "3xl":  { "$type": "dimension", "$value": "2.5rem",    "$description": "40px — login hero headline", "$extensions": { "cssVar": "--font-size-3xl" } }
    },

    "fontWeight": {
      "regular":   { "$type": "fontWeight", "$value": 400 },
      "medium-alt":{ "$type": "fontWeight", "$value": 450, "$description": "Inter-specific intermediate weight for sidebar items" },
      "medium":    { "$type": "fontWeight", "$value": 500 },
      "semibold":  { "$type": "fontWeight", "$value": 600 },
      "bold":      { "$type": "fontWeight", "$value": 700 },
      "extrabold": { "$type": "fontWeight", "$value": 800 }
    },

    "lineHeight": {
      "tight":    { "$type": "number", "$value": 1.2, "$description": "Display headings" },
      "snug":     { "$type": "number", "$value": 1.4, "$description": "Compact UI labels" },
      "normal":   { "$type": "number", "$value": 1.5, "$description": "Card titles, panel headings" },
      "relaxed":  { "$type": "number", "$value": 1.6, "$description": "Default body text" },
      "loose":    { "$type": "number", "$value": 1.7, "$description": "Markdown prose paragraphs" }
    }
  },

  "spacing": {
    "$description": "8px-base spacing scale.",
    "xs":  { "$type": "dimension", "$value": "4px",  "$extensions": { "cssVar": "--space-xs" } },
    "sm":  { "$type": "dimension", "$value": "8px",  "$extensions": { "cssVar": "--space-sm" } },
    "md":  { "$type": "dimension", "$value": "12px", "$extensions": { "cssVar": "--space-md" } },
    "lg":  { "$type": "dimension", "$value": "16px", "$extensions": { "cssVar": "--space-lg" } },
    "xl":  { "$type": "dimension", "$value": "24px", "$extensions": { "cssVar": "--space-xl" } },
    "2xl": { "$type": "dimension", "$value": "32px", "$extensions": { "cssVar": "--space-2xl" } },
    "3xl": { "$type": "dimension", "$value": "48px", "$extensions": { "cssVar": "--space-3xl" } },
    "4xl": { "$type": "dimension", "$value": "64px", "$extensions": { "cssVar": "--space-4xl" } }
  },

  "borderRadius": {
    "$description": "Corner radius scale.",
    "sm":   { "$type": "dimension", "$value": "6px",   "$extensions": { "cssVar": "--radius-sm" } },
    "md":   { "$type": "dimension", "$value": "10px",  "$extensions": { "cssVar": "--radius-md" } },
    "lg":   { "$type": "dimension", "$value": "14px",  "$extensions": { "cssVar": "--radius-lg" } },
    "xl":   { "$type": "dimension", "$value": "20px",  "$extensions": { "cssVar": "--radius-xl" } },
    "full": { "$type": "dimension", "$value": "999px", "$extensions": { "cssVar": "--radius-full" } }
  },

  "shadow": {
    "$description": "Elevation shadow scale. Values shown for dark theme.",
    "sm": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "1px", "blur": "3px", "spread": "0", "color": "rgba(0,0,0,0.3)" },
      "$extensions": { "cssVar": "--shadow-sm" }
    },
    "md": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "0", "color": "rgba(0,0,0,0.4)" },
      "$extensions": { "cssVar": "--shadow-md" }
    },
    "lg": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "8px", "blur": "30px", "spread": "0", "color": "rgba(0,0,0,0.5)" },
      "$extensions": { "cssVar": "--shadow-lg" }
    },
    "xl": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "20px", "blur": "60px", "spread": "0", "color": "rgba(0,0,0,0.6)" },
      "$extensions": { "cssVar": "--shadow-xl" }
    }
  },

  "motion": {
    "$description": "Transition and animation timing tokens.",
    "duration": {
      "fast":   { "$type": "duration", "$value": "120ms", "$extensions": { "cssVar": "--transition-fast" } },
      "normal": { "$type": "duration", "$value": "200ms", "$extensions": { "cssVar": "--transition-normal" } },
      "slow":   { "$type": "duration", "$value": "350ms", "$extensions": { "cssVar": "--transition-slow" } }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1], "$description": "Standard ease for layout transitions" },
      "spring":   { "$type": "cubicBezier", "$value": [0.175, 0.885, 0.32, 1.275], "$description": "Spring snap for drops/snaps" },
      "ease-out": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1], "$description": "Entering elements" },
      "ease-in":  { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1], "$description": "Exiting elements" }
    }
  },

  "zIndex": {
    "$description": "Z-axis stacking scale.",
    "sidebar":   { "$type": "number", "$value": 100, "$extensions": { "cssVar": "--z-sidebar" } },
    "overlay":   { "$type": "number", "$value": 200, "$extensions": { "cssVar": "--z-overlay" } },
    "modal":     { "$type": "number", "$value": 300, "$extensions": { "cssVar": "--z-modal" } },
    "dropdown":  { "$type": "number", "$value": 350, "$extensions": { "cssVar": "--z-dropdown" } },
    "toast":     { "$type": "number", "$value": 400, "$extensions": { "cssVar": "--z-toast" } },
    "spotlight": { "$type": "number", "$value": 500, "$extensions": { "cssVar": "--z-spotlight" } }
  },

  "layout": {
    "$description": "Fixed structural layout dimensions.",
    "sidebarWidth":    { "$type": "dimension", "$value": "260px", "$extensions": { "cssVar": "--sidebar-width" } },
    "noteslistWidth":  { "$type": "dimension", "$value": "320px", "$extensions": { "cssVar": "--noteslist-width" } },
    "toolbarHeight":   { "$type": "dimension", "$value": "48px",  "$extensions": { "cssVar": "--toolbar-height" } },
    "headerHeight":    { "$type": "dimension", "$value": "56px",  "$extensions": { "cssVar": "--header-height" } }
  }
}
